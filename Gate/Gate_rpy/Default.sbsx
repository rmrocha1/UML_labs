		<IUseCase type="e">
			<_id type="a">GUID ad5a6551-1503-49b8-9b8e-eca444a48030</_id>
			<_myState type="a">8192</_myState>
			<_name type="a">Receiving signal from RC</_name>
			<_modifiedTimeWeak type="a">1.2.1990::0:0:0</_modifiedTimeWeak>
			<_description type="p"><IDescription type="e">
				<_text type="a">After receiving the signal the receiver should:%0D
1. Validate the recorded signal according to the defined requierments%0D
2. If the signal meets the requirements, send it to the Controller for interpretation.%0D
2.1. If the gate was moving at a given moment, it should be stopped, remembering the direction in which it was moving.%0D
2.2. If the gate was at rest, start the movement in the opposite direction of the previous one.%0D
3. If the signal is incorrect, ignore it.</_text>
			</IDescription>
			</_description>
			<_modifiedTime type="a">6.2.2026::15:59:11</_modifiedTime>
			<_lastID type="a">1</_lastID>
			<weakCGTime type="a">1.2.1990::0:0:0</weakCGTime>
